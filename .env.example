# Dutopia environment configuration
# Copy to .env and set values for your deployment.

# Required for duapi JWT signing
JWT_SECRET=change-me

# Optional: comma-separated admin usernames
ADMIN_GROUP=

# PAM service name (Unix auth). Defaults to "login".
PAM_SERVICE=login

# duapi server configuration
PORT=8080
STATIC_DIR=./public
BASE_PATH=/

# CORS allowed origin for browser UI (e.g. http://localhost:5173)
CORS_ORIGIN=

# TLS (optional)
TLS_CERT=
TLS_KEY=

# Request/limit controls
REQUEST_TIMEOUT_SECS=30
RATE_LIMIT_PER_MIN=300
# Maximum request body size in bytes (login JSON, etc.)
MAX_BODY_BYTES=65536
MAX_PAGE_SIZE=2000

# Logging
RUST_LOG=info
DUTOPIA_LOG_FORMAT=json

# Cleanup-request email notifications (browser build).
# When all SMTP_* vars AND MAIL_DOMAIN are set, the server exposes
# smtp_configured=true via /api/health and the "Notify user" button in the
# cleanup panel becomes active. Recipient addresses are synthesized as
# {username}@{MAIL_DOMAIN}.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
MAIL_DOMAIN=
